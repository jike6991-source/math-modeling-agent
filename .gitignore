# 敏感信息
.env

# 生成产物（保留目录占位文件）
outputs/*
!outputs/.gitkeep

# projects/ 下每道题的图表为生成产物，不提交；分析结果、代码、论文仍跟踪
projects/**/*.png
projects/**/*.jpg
projects/**/*.jpeg
projects/**/*.svg
projects/**/*.gif

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# 虚拟环境
.venv/
venv/
env/

# 向量库 / RAG 缓存（Phase 2）
chroma/
.chroma/
*.sqlite3

# 知识库（Phase 2）：原始 PDF 与 Chroma 持久化库不入 git；processed/ 切片产物保留
knowledge/papers/*
!knowledge/papers/.gitkeep
knowledge/chroma_db/*
!knowledge/chroma_db/.gitkeep

# 用户上传的数据附件（各项目子目录内的 data/ 文件夹）
projects/**/data/

# IDE
.idea/
.vscode/
.DS_Store
